# graphifyignore — exclude non-app code from the knowledge graph
# gitignore-style patterns, relative to this file's directory

# PHP vendor dependencies
vendor/

# Node modules
node_modules/

# Frontend build output
public/build/
public/js/
public/css/

# Third-party frontend libraries bundled in resources
resources/libs/
resources/fonts/

# Compiled assets
resources/css/
public/images/

# Graphify tooling itself
graphify/
graphify-out/

# Storage / logs / caches
storage/
bootstrap/cache/

# Test snapshots and fixtures (keep test PHP files themselves)
tests/fixtures/

# Obsidian vault (markdown only, not code)
obsidian-vaults/

# Scripts (one-off utility scripts, not app code)
scripts/
