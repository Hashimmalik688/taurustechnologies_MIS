            <div class="ld-pipe-body">
                @foreach($steps as $idx => $step)
                    @php
                        $isDone = in_array($step['key'], $done);
                        $isCurr = $step['key'] === $currentStep;
                        $cls = $isDone ? 's-done' : ($isCurr ? 's-current' : '');
                        // Dynamic sub-text
                        $subText = $step['sub'];
                        if ($isDone) { $subText = 'Completed'; }
                        elseif ($isCurr) { $subText = 'In progress'; }
                    @endphp
                    <div class="ld-step {{ $cls }}">
                        <div class="ld-step-check">
                            @if($isDone) <i class="mdi mdi-check"></i>
                            @elseif($isCurr) <i class="mdi mdi-dots-horizontal"></i>
                            @endif
                        </div>
                        <div class="ld-step-info">
                            <div class="ld-step-name"><i class="mdi {{ $step['icon'] }}"></i> {{ $step['label'] }}</div>
                            @if($subText)<div class="ld-step-sub">{{ $subText }}</div>@endif
                        </div>
                    </div>
                @endforeach
            </div>
        </div>
