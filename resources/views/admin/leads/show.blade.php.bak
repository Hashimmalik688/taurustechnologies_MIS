    {{-- ══ Top Bar: Header (left) + Pipeline Steps (right) ══ --}}
    @php
        // ── Pipeline step logic ──
        $steps = [
            ['key'=>'sale',     'label'=>'Sale Made',             'icon'=>'mdi-handshake',          'sub'=>''],
            ['key'=>'submit',   'label'=>'Submitted to Carrier',  'icon'=>'mdi-file-upload',        'sub'=>''],
            ['key'=>'issuance', 'label'=>'Policy Issuance',       'icon'=>'mdi-file-document-check','sub'=>''],
            ['key'=>'followup', 'label'=>'Client Follow-up',      'icon'=>'mdi-phone-in-talk',      'sub'=>''],
            ['key'=>'banking',  'label'=>'Banking Verification',  'icon'=>'mdi-bank-check',         'sub'=>''],
            ['key'=>'draft',    'label'=>'Draft Confirmation',    'icon'=>'mdi-check-circle',       'sub'=>'Future module'],
            ['key'=>'commission','label'=>'Commission Statement', 'icon'=>'mdi-currency-usd',       'sub'=>'Future module'],
            ['key'=>'paid',     'label'=>'Paid',                  'icon'=>'mdi-cash-check',         'sub'=>'Future module'],
            ['key'=>'recovery', 'label'=>'Advance Recovery',      'icon'=>'mdi-refresh',            'sub'=>'Future module'],
        ];

        $done = [];

        // Step 1: Sale Made — status is 'sale' or 'accepted'
        $isSale = in_array($insurance->status, ['sale','accepted']);
        if ($isSale) { $done[] = 'sale'; }

        // Step 2: Submitted to Carrier — status 'underwritten', or auto if approved/accepted
        if ($insurance->status === 'underwritten' || $isSale) {
            $done[] = 'sale'; $done[] = 'submit';
        }

        // Step 3: Policy Issuance — policy_number assigned AND partner assigned
        $hasIssuance = ($insurance->policy_number || $insurance->issued_policy_number) && ($insurance->partner_id || $insurance->assigned_partner);
        if ($hasIssuance) {
            $done[] = 'sale'; $done[] = 'submit'; $done[] = 'issuance';
        }

        // Step 4: Client Follow-up — followup_status is Yes or No AND followup person assigned
        $hasFollowup = in_array($insurance->followup_status, ['Yes','No','Completed','yes','no','completed']) && ($insurance->assigned_followup_person || $insurance->followup_assigned_by);
        if ($hasFollowup) {
            $done[] = 'sale'; $done[] = 'submit'; $done[] = 'issuance'; $done[] = 'followup';
        }

        // Step 5: Banking Verification — bank_verification_status is 'BV Verified' or 'verified'
        $hasBV = in_array(strtolower($insurance->bank_verification_status ?? ''), ['bv verified','verified']);
        if ($hasBV) {
            $done[] = 'sale'; $done[] = 'submit'; $done[] = 'issuance'; $done[] = 'followup'; $done[] = 'banking';
        }

        $done = array_unique($done);

        // Determine current step (first uncompleted)
        $currentStep = null;
        foreach ($steps as $s) {
            if (!in_array($s['key'], $done)) { $currentStep = $s['key']; break; }
        }
    @endphp

