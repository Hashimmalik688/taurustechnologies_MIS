/* connector line between dots */
.ld-st:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 11px; left: calc(50% + 12px); right: calc(-50% + 12px);
    height: 2px;
    background: var(--bs-surface-200);
    z-index: 0;
}
.ld-st.s-done:not(:last-child)::after { background: var(--bs-gold); }
.ld-st.s-done + .ld-st.s-current::before {
    content: '';
    position: absolute;
    top: 11px; right: calc(50% + 12px); left: calc(-50% + 12px);
    height: 2px;
    background: var(--bs-gold);
    z-index: 0;
}
.ld-st-dot {
