    z-index: 1; position: relative;
    transition: all .2s;
}
.ld-st.s-done .ld-st-dot {
    background: var(--bs-gold); border-color: var(--bs-gold);
    color: #fff; box-shadow: 0 1px 4px rgba(212,175,55,.3);
}
.ld-st.s-current .ld-st-dot {
    background: #34c38f; border-color: #34c38f;
    color: #fff; box-shadow: 0 0 0 3px rgba(52,195,143,.2);
    animation: stPulse 2s infinite;
}
