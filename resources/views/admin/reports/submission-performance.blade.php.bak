    {{-- Donut chart --}}
    @if($carriersData->isNotEmpty())
    <div class="sp-donut-panel">
        <div class="sp-donut-title">Sales Distribution</div>
        @php
            $cx=80;$cy=80;$innerR=51;$circumference=2*M_PI*$innerR;
            $cumPct=0;$slices=[];
            foreach($carriersData as $i=>$row){
                $pct=$grandTotal>0?$row->total_sales/$grandTotal:0;
                $slices[]=['pct'=>$pct,'color'=>$palette[$i%count($palette)],'cum'=>$cumPct,'label'=>($row->carrier_name?:'?').($row->assigned_partner?' · '.$row->assigned_partner:'')];
                $cumPct+=$pct;
            }
        @endphp
        <svg viewBox="0 0 160 160" style="width:100%;max-width:160px;display:block;margin:0 auto">
            <circle cx="{{ $cx }}" cy="{{ $cy }}" r="{{ $innerR }}" fill="none" stroke="rgba(0,0,0,.06)" stroke-width="20"/>
            @foreach($slices as $sl)
            @php
                $dash=$circumference*$sl['pct'];
                $gap=$circumference-$dash;
                $startOff=$circumference*0.25-$circumference*$sl['cum'];
            @endphp
            <circle cx="{{ $cx }}" cy="{{ $cy }}" r="{{ $innerR }}" fill="none" stroke="{{ $sl['color'] }}" stroke-width="20"
                stroke-dasharray="{{ number_format($dash,4,'.',''). ' ' .number_format($gap,4,'.','')}}"
                stroke-dashoffset="{{ number_format($startOff,4,'.','')}}" />
            @endforeach
            <text x="{{ $cx }}" y="{{ $cy-6 }}" text-anchor="middle" font-size="17" font-weight="800" fill="var(--bs-surface-900,#1e293b)">{{ number_format($grandTotalSales) }}</text>
            <text x="{{ $cx }}" y="{{ $cy+10 }}" text-anchor="middle" font-size="8" fill="var(--bs-surface-400,#94a3b8)" font-weight="600" letter-spacing=".4">SALES</text>
        </svg>
        <div style="margin-top:.45rem">
            @foreach($carriersData->take(7) as $i=>$row)
            @php $lPct=$grandTotal>0?round(($row->total_sales/$grandTotal)*100,1):0 @endphp
            <div class="sp-legend-item">
                <span class="sp-legend-dot" style="background:{{ $palette[$i%count($palette)] }}"></span>
                <span class="sp-legend-lbl">{{ $row->carrier_name?:'Unknown' }}@if($row->assigned_partner) <span style="opacity:.6">· {{ $row->assigned_partner }}</span>@endif</span>
                <span class="sp-legend-pct">{{ $lPct }}%</span>
            </div>
            @endforeach
            @if($carriersData->count()>7)<div style="font-size:.58rem;color:var(--bs-surface-400,#94a3b8);margin-top:.15rem">+{{ $carriersData->count()-7 }} more</div>@endif
        </div>
    </div>
    @endif

</div>

<p style="font-size:.6rem;color:var(--bs-surface-400,#94a3b8);text-align:center;margin-top:.45rem">
