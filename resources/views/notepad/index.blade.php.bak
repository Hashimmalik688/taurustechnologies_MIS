@section('script')
<script>
const CSRF = '{{ csrf_token() }}';
let newSelectedColor = '#ffffff';
let editSelectedColor = '#ffffff';

// ── Color pickers ──
function selectNewColor(el) {
    document.querySelectorAll('#newColorRow .np-color-dot').forEach(d => d.classList.remove('active'));
    el.classList.add('active');
    newSelectedColor = el.dataset.color;
}
function selectEditColor(el) {
    document.querySelectorAll('#editColorRow .np-color-dot').forEach(d => d.classList.remove('active'));
    el.classList.add('active');
    editSelectedColor = el.dataset.color;
}

// Activate first color on page load
document.querySelectorAll('#newColorRow .np-color-dot')[6]?.classList.add('active');

// ── Add Note ──
async function addNote() {
    const title   = document.getElementById('newTitle').value.trim();
    const content = document.getElementById('newContent').value.trim();
    const btn     = document.getElementById('btnAddNote');

    if (!title && !content) return;

    btn.disabled = true;
    try {
        const res = await fetch('{{ route("notepad.store") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': CSRF,
                'Accept': 'application/json',
            },
            body: JSON.stringify({ title, content, color: newSelectedColor }),
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('newTitle').value = '';
            document.getElementById('newContent').value = '';
            prependNoteCard(data.note);
            updateStats();
        }
    } catch (e) {
        console.error('Add note failed', e);
    }
    btn.disabled = false;
}

// ── Delete Note ──
async function deleteNote(id) {
    if (!confirm('Delete this note?')) return;
    try {
        const res = await fetch(`/notepad/${id}`, {
            method: 'DELETE',
            headers: { 'X-CSRF-TOKEN': CSRF, 'Accept': 'application/json' },
        });
        const data = await res.json();
        if (data.success) {
            const card = document.getElementById(`note-${id}`);
            if (card) card.remove();
            checkEmpty();
            updateStats();
        }
    } catch (e) { console.error('Delete note failed', e); }
}

// ── Toggle Pin ──
async function togglePin(id, pinEl) {
    const card   = document.getElementById(`note-${id}`);
    const pinned = card.dataset.pinned === '1' ? false : true;
    try {
        const res = await fetch(`/notepad/${id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': CSRF,
                'Accept': 'application/json',
            },
            body: JSON.stringify({ is_pinned: pinned }),
        });
        const data = await res.json();
        if (data.success) {
            card.dataset.pinned = pinned ? '1' : '0';
            pinEl.classList.toggle('pinned', pinned);
            pinEl.querySelector('i').className = pinned ? 'bx bxs-pin' : 'bx bx-pin';
            pinEl.title = pinned ? 'Unpin' : 'Pin';
            updateStats();
        }
    } catch (e) { console.error('Toggle pin failed', e); }
}

// ── Edit Modal ──
function openEdit(id) {
    const card = document.getElementById(`note-${id}`);
    document.getElementById('editNoteId').value  = id;
    document.getElementById('editTitle').value   = card.dataset.title;
    document.getElementById('editContent').value = card.dataset.content;
    editSelectedColor = card.dataset.color || '#ffffff';

    // Activate matching color dot
    document.querySelectorAll('#editColorRow .np-color-dot').forEach(d => {
        d.classList.toggle('active', d.dataset.color === editSelectedColor);
    });

    document.getElementById('editModal').classList.add('show');
}
function closeEdit() {
    document.getElementById('editModal').classList.remove('show');
}
async function saveEdit() {
    const id      = document.getElementById('editNoteId').value;
    const title   = document.getElementById('editTitle').value.trim();
    const content = document.getElementById('editContent').value.trim();

    try {
        const res = await fetch(`/notepad/${id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': CSRF,
                'Accept': 'application/json',
            },
            body: JSON.stringify({ title, content, color: editSelectedColor }),
        });
        const data = await res.json();
        if (data.success) {
            const note = data.note;
            const card = document.getElementById(`note-${id}`);
            card.style.background       = note.color;
            card.dataset.title          = note.title || '';
            card.dataset.content        = note.content || '';
            card.dataset.color          = note.color;
            card.dataset.updated        = Math.floor(Date.now() / 1000);

            const titleEl = card.querySelector('.np-card-title');
            if (titleEl) titleEl.textContent = note.title || '';
            card.querySelector('.np-card-body').textContent = note.content || '';
            card.querySelector('.np-card-footer span').textContent = note.updated_ago;
            closeEdit();
        }
    } catch (e) { console.error('Save edit failed', e); }
}

// Close modal on backdrop click
document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) closeEdit();
});

// Enter key in new-note title → focus content
document.getElementById('newTitle').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('newContent').focus(); }
});

// ── Render helpers ──
function prependNoteCard(note) {
    const empty = document.getElementById('npEmpty');
    if (empty) empty.remove();

    const grid = document.getElementById('npGrid');
    const card = buildCard(note);
    grid.insertAdjacentHTML('afterbegin', card);
}

function buildCard(note) {
    const title   = note.title ? `<div class="np-card-title">${esc(note.title)}</div>` : '';
    const content = esc(note.content || '');
    return `
    <div class="np-card" id="note-${note.id}"
         style="background:${note.color}"
         data-id="${note.id}"
         data-title="${esc(note.title || '')}"
         data-content="${esc(note.content || '')}"
         data-color="${note.color}"
         data-pinned="0"
         data-updated="${Math.floor(Date.now()/1000)}">
        <div class="np-card-pin" onclick="togglePin(${note.id}, this)" title="Pin">
            <i class="bx bx-pin"></i>
        </div>
        ${title}
        <div class="np-card-body">${content}</div>
        <div class="np-card-footer">
            <span>${note.updated_ago}</span>
            <div class="np-card-actions">
                <button onclick="openEdit(${note.id})" title="Edit"><i class="bx bx-edit-alt"></i></button>
                <button onclick="deleteNote(${note.id})" title="Delete"><i class="bx bx-trash"></i></button>
            </div>
        </div>
    </div>`;
}

function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function checkEmpty() {
    const grid = document.getElementById('npGrid');
    if (!grid.querySelector('.np-card')) {
        grid.innerHTML = `<div class="np-empty" id="npEmpty" style="grid-column: 1 / -1;">
            <i class="bx bx-notepad"></i><p>No notes yet. Start writing above!</p></div>`;
    }
}

function updateStats() {
    const cards  = document.querySelectorAll('.np-card');
    const pinned = document.querySelectorAll('.np-card .np-card-pin.pinned');
    document.getElementById('statTotal').textContent  = cards.length;
    document.getElementById('statPinned').textContent = pinned.length;
}

// ── Search/filter ──
function filterNotes() {
    const q = document.getElementById('npSearch').value.toLowerCase();
    document.querySelectorAll('.np-card').forEach(card => {
        const title   = (card.dataset.title   || '').toLowerCase();
        const content = (card.dataset.content || '').toLowerCase();
        card.style.display = (!q || title.includes(q) || content.includes(q)) ? '' : 'none';
    });
}

// Enter to add note from content textarea
document.getElementById('newContent').addEventListener('keydown', function(e) {
    if (e.ctrlKey && e.key === 'Enter') addNote();
});
</script>
@endsection
